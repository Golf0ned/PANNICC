  %9 = load ptr %2
  br i32 %9, label 10, label 18

10:
  %11 = load ptr %1
  %12 = load ptr %0
  %13 = add i32 %11, i32 %12
  store i32 %13, ptr %3
  %14 = load ptr %3
  store i32 %14, ptr %1
  %15 = load ptr %0
  %16 = add i32 %15, i32 1
  store i32 %16, ptr %4
  %17 = load ptr %4
  store i32 %17, ptr %0
  br label 6

18:
