define i32 @mem2reg_branching(i32 %0) {
entry:
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  store i32 %0, ptr %1
  %6 = load ptr %1
  %7 = sub i32 %6, i32 42
  store i32 %7, ptr %3
  %8 = load ptr %3
  br i32 %8, label 9, label 10

9:
  store i32 1, ptr %2
  br label 14

10:
  %11 = load ptr %1
  %12 = add i32 %11, i32 2
  store i32 %12, ptr %4
  %13 = load ptr %4
  store i32 %13, ptr %2
  br label 14

14:
  %15 = load ptr %2
  store i32 %15, ptr %5
  br label 16

16:
  %17 = load ptr %5
  ret i32 %17
}

define i32 @mem2reg_while() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
