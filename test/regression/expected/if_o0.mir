define i32 @if_basic() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 1, ptr %1
  %3 = load ptr %1
  br i32 %3, label 4, label 8

4:
  %5 = load ptr %1
  %6 = add i32 %5, i32 100
  store i32 %6, ptr %2
  %7 = load ptr %2
  store i32 %7, ptr %1
  br label 8

8:
  %9 = load ptr %1
  store i32 %9, ptr %0
  br label 10

10:
  %11 = load ptr %0
  ret i32 %11
}

define i32 @if_basic_else() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  store i32 1, ptr %1
  %4 = load ptr %1
  br i32 %4, label 5, label 9

5:
  %6 = load ptr %1
  %7 = add i32 %6, i32 3
  store i32 %7, ptr %2
  %8 = load ptr %2
  store i32 %8, ptr %1
  br label 13

9:
  %10 = load ptr %1
  %11 = add i32 %10, i32 100
  store i32 %11, ptr %3
  %12 = load ptr %3
  store i32 %12, ptr %1
  br label 13

13:
  %14 = load ptr %1
  store i32 %14, ptr %0
  br label 15

15:
  %16 = load ptr %0
  ret i32 %16
}

define i32 @if_no_braces() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  store i32 1, ptr %1
  %2 = load ptr %1
  br i32 %2, label 3, label 6

3:
  %4 = load ptr %1
  store i32 %4, ptr %0
  br label 9

5:
  br label 11

6:
  %7 = load ptr %1
  store i32 %7, ptr %0
  br label 9

8:
  br label 11

9:
  %10 = load ptr %0
  ret i32 %10

11:
  br label 9
}

define i32 @if_chain() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 1, ptr %1
  store i32 2, ptr %2
  %3 = load ptr %1
  br i32 %3, label 4, label 9

4:
  %5 = load ptr %2
  br i32 %5, label 6, label 8

6:
  store i32 0, ptr %0
  br label 10

7:
  br label 8

8:
  br label 9

9:
  store i32 1, ptr %0
  br label 10

10:
  %11 = load ptr %0
  ret i32 %11
}

define i32 @if_chain_many() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  store i32 1, ptr %1
  store i32 2, ptr %2
  store i32 0, ptr %3
  %4 = load ptr %1
  br i32 %4, label 5, label 15

5:
  %6 = load ptr %2
  br i32 %6, label 7, label 14

7:
  %8 = load ptr %3
  br i32 %8, label 9, label 11

9:
  store i32 0, ptr %0
  br label 16

10:
  br label 13

11:
  store i32 3, ptr %0
  br label 16

12:
  br label 13

13:
  br label 14

14:
  br label 15

15:
  store i32 1, ptr %0
  br label 16

16:
  %17 = load ptr %0
