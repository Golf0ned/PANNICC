define i32 @if_basic() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 1, ptr %0
  %3 = load ptr %0
  br i32 %3, label 4, label 8

4:
  %5 = load ptr %0
  %6 = add i32 %5, i32 100
  store i32 %6, ptr %1
  %7 = load ptr %1
  store i32 %7, ptr %0
  br label 8

8:
  %9 = load ptr %0
  store i32 %9, ptr %2
  br label 10

10:
  %11 = load ptr %2
  ret i32 %11
}

define i32 @if_basic_else() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  store i32 1, ptr %0
  %4 = load ptr %0
  br i32 %4, label 5, label 9

5:
  %6 = load ptr %0
  %7 = add i32 %6, i32 3
  store i32 %7, ptr %1
  %8 = load ptr %1
  store i32 %8, ptr %0
  br label 13

9:
  %10 = load ptr %0
  %11 = add i32 %10, i32 100
  store i32 %11, ptr %2
  %12 = load ptr %2
  store i32 %12, ptr %0
  br label 13

13:
  %14 = load ptr %0
  store i32 %14, ptr %3
  br label 15

15:
  %16 = load ptr %3
  ret i32 %16
}

define i32 @if_no_braces() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  store i32 1, ptr %0
  %2 = load ptr %0
  br i32 %2, label 3, label 5

3:
  %4 = load ptr %0
  store i32 %4, ptr %1
  br label 8

5:
  %6 = load ptr %0
  store i32 %6, ptr %1
  br label 8

7:
  br label 8

8:
  %9 = load ptr %1
  ret i32 %9
}

define i32 @if_chain() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 1, ptr %0
  store i32 2, ptr %1
  %3 = load ptr %0
  br i32 %3, label 4, label 8

4:
  %5 = load ptr %1
  br i32 %5, label 6, label 7

6:
  store i32 0, ptr %2
  br label 9

7:
  br label 8

8:
  store i32 1, ptr %2
  br label 9

9:
  %10 = load ptr %2
  ret i32 %10
}

define i32 @if_chain_many() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  store i32 1, ptr %0
  store i32 2, ptr %1
  store i32 0, ptr %2
  %4 = load ptr %0
  br i32 %4, label 5, label 13

5:
  %6 = load ptr %1
  br i32 %6, label 7, label 12

7:
  %8 = load ptr %2
  br i32 %8, label 9, label 10

9:
  store i32 0, ptr %3
  br label 14

10:
  store i32 3, ptr %3
  br label 14

11:
  br label 12

12:
  br label 13

13:
  store i32 1, ptr %3
  br label 14

14:
  %15 = load ptr %3
  ret i32 %15
}

define i32 @if_else_if() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 2

1:
  store i32 2, ptr %0
  br label 7

2:
  br i32 3, label 3, label 4

3:
  store i32 4, ptr %0
  br label 7

4:
  store i32 5, ptr %0
  br label 7

5:
  br label 6

6:
  br label 7

7:
  %8 = load ptr %0
  ret i32 %8
}