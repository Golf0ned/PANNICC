}

define i32 @if_else_if() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 3

1:
  store i32 2, ptr %0
  br label 9

2:
  br label 11

3:
  br i32 3, label 4, label 6

4:
  store i32 4, ptr %0
  br label 9

5:
  br label 8

6:
  store i32 5, ptr %0
  br label 9

7:
  br label 8

8:
  br label 11

9:
  %10 = load ptr %0
  ret i32 %10

11:
