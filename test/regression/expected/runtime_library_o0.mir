declare ptr @alloc(i32)

declare i32 @dealloc(ptr)

declare i32 @print(i32)

define i32 @main() {
entry:
  %0 = alloca i32
  %1 = alloca ptr
  %2 = alloca ptr
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  %6 = call ptr @alloc(i32 4)
  store ptr %6, ptr %2
  %7 = load ptr %2
  store ptr %7, ptr %1
  %8 = load ptr %1
  store i32 67, ptr %8
  %9 = load ptr %1
  %10 = load ptr %9
  store i32 %10, ptr %3
  %11 = load ptr %3
  %12 = call i32 @print(i32 %11)
  store i32 %12, ptr %4
  %13 = load ptr %1
  %14 = call i32 @dealloc(ptr %13)
  store i32 %14, ptr %5
  store i32 0, ptr %0
  br label 15

15:
  %16 = load ptr %0
  ret i32 %16
}