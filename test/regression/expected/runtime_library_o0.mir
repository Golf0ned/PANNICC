declare ptr @alloc(i32)

declare i32 @dealloc(ptr)

declare i32 @print(i32)

define i32 @main() {
entry:
  %0 = alloca i32
  %1 = alloca ptr
  %2 = alloca ptr
  %3 = alloca i32
  %4 = alloca i32
  %5 = call i32 @print(i32 67)
  store i32 %5, ptr %0
  %6 = call ptr @alloc(i32 4)
  store ptr %6, ptr %2
  %7 = load ptr %2
  store ptr %7, ptr %1
  %8 = load ptr %1
  %9 = call i32 @dealloc(ptr %8)
  store i32 %9, ptr %3
  store i32 0, ptr %4
  br label 10

10:
  %11 = load ptr %4
  ret i32 %11
}