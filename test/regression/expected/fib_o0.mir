define i32 @fib_rec(i32 %0) {
entry:
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  %6 = alloca i32
  %7 = alloca i32
  %8 = alloca i32
  store i32 %0, ptr %8
  %9 = load ptr %8
  br i32 %9, label 10, label 30

10:
  %11 = load ptr %8
  %12 = sub i32 %11, i32 1
  store i32 %12, ptr %1
  %13 = load ptr %1
  br i32 %13, label 14, label 28

14:
  %15 = load ptr %8
  %16 = sub i32 %15, i32 1
  store i32 %16, ptr %2
  %17 = load ptr %2
  %18 = call i32 @fib_rec(i32 %17)
  store i32 %18, ptr %3
  %19 = load ptr %8
  %20 = sub i32 %19, i32 2
  store i32 %20, ptr %4
  %21 = load ptr %4
  %22 = call i32 @fib_rec(i32 %21)
  store i32 %22, ptr %5
  %23 = load ptr %3
  %24 = load ptr %5
  %25 = add i32 %23, i32 %24
  store i32 %25, ptr %6
  %26 = load ptr %6
  store i32 %26, ptr %7
  br label 31

27:
  br label 28

28:
  store i32 1, ptr %7
  br label 31

29:
  br label 30

30:
  store i32 0, ptr %7
  br label 31

31:
  %32 = load ptr %7
  ret i32 %32
}

define i32 @fib_it(i32 %0) {
entry:
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  %6 = alloca i32
  store i32 %0, ptr %6
  store i32 0, ptr %1
  store i32 1, ptr %2
  br label 7

7:
  %8 = load ptr %6
  br i32 %8, label 9, label 18

9:
  %10 = load ptr %1
  %11 = load ptr %2
  %12 = add i32 %10, i32 %11
  store i32 %12, ptr %4
  %13 = load ptr %4
  store i32 %13, ptr %3
  %14 = load ptr %2
  store i32 %14, ptr %1
  %15 = load ptr %3
  store i32 %15, ptr %2
  %16 = load ptr %6
  %17 = sub i32 %16, i32 1
  store i32 %17, ptr %6
  br label 7

18:
  %19 = load ptr %1
  store i32 %19, ptr %5
  br label 20

20:
  %21 = load ptr %5
  ret i32 %21
}

define i32 @main() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = call i32 @fib_rec(i32 10)
  store i32 %4, ptr %0
  %5 = call i32 @fib_it(i32 1000)
  store i32 %5, ptr %1
  %6 = load ptr %0
  %7 = load ptr %1
  %8 = add i32 %6, i32 %7
  store i32 %8, ptr %2
  %9 = load ptr %2
  store i32 %9, ptr %3
  br label 10

10:
  %11 = load ptr %3
  ret i32 %11
}