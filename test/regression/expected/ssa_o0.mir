define i32 @lost_copy_problem(i32 %0) {
entry:
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  store i32 %0, ptr %1
  br label 6

6:
  %7 = load ptr %1
  %8 = sub i32 %7, i32 10
  store i32 %8, ptr %4
  %9 = load ptr %4
  br i32 %9, label 10, label 14

10:
  %11 = load ptr %1
  store i32 %11, ptr %3
  %12 = load ptr %1
  %13 = add i32 %12, i32 1
  store i32 %13, ptr %1
  br label 6

14:
  %15 = load ptr %3
  %16 = add i32 %15, i32 3
  store i32 %16, ptr %5
  %17 = load ptr %5
  store i32 %17, ptr %2
  br label 18

18:
  %19 = load ptr %2
  ret i32 %19
}

define i32 @swap_problem(i32 %0, i32 %1) {
entry:
  %2 = alloca i32
  %3 = alloca i32
  %4 = alloca i32
  %5 = alloca i32
  %6 = alloca i32
  store i32 %0, ptr %2
  store i32 %1, ptr %3
  br label 7

7:
  br i32 1, label 8, label 12

8:
  %9 = load ptr %2
  store i32 %9, ptr %5
  %10 = load ptr %3
  store i32 %10, ptr %2
  %11 = load ptr %5
  store i32 %11, ptr %3
  br label 7

12:
  %13 = load ptr %2
  %14 = load ptr %3
  %15 = add i32 %13, i32 %14
  store i32 %15, ptr %6
  %16 = load ptr %6
  store i32 %16, ptr %4
  br label 17

17:
  %18 = load ptr %4
  ret i32 %18
}