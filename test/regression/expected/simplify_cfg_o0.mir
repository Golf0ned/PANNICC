define i32 @simplify_cfg_delete_orphaned() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 2

1:
  store i32 2, ptr %0
  br label 4

2:
  store i32 3, ptr %0
  br label 4

3:
  br label 4

4:
  %5 = load ptr %0
  ret i32 %5
}

define i32 @simplify_cfg_merge_straight_line() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 0, ptr %0
  br i32 1, label 3, label 9

3:
  br i32 2, label 4, label 5

4:
  store i32 3, ptr %2
  br label 12

5:
  %6 = load ptr %0
  %7 = add i32 %6, i32 4
  store i32 %7, ptr %1
  %8 = load ptr %1
  store i32 %8, ptr %0
  br label 10

9:
  store i32 5, ptr %2
  br label 12

10:
  %11 = load ptr %0
  store i32 %11, ptr %2
  br label 12

12:
  %13 = load ptr %2
  ret i32 %13
}

define i32 @simplify_cfg_delete_empty() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 5

1:
  br i32 2, label 2, label 3

2:
  br label 4

3:
  br label 4

4:
  br label 9

5:
  br i32 3, label 6, label 7

6:
  br label 8

7:
  br label 8

8:
  br label 9

9:
  store i32 4, ptr %0
  br label 10

10:
  %11 = load ptr %0
  ret i32 %11
}

define i32 @simplify_cfg_empty_loop() {
entry:
  %0 = alloca i32
  br label 1

1:
  br i32 0, label 2, label 3

2:
  br label 1

3:
  store i32 0, ptr %0
  br label 4

4:
  %5 = load ptr %0
  ret i32 %5
}