define i32 @basic(i32 %0) {
entry:
  %1 = add i32 %0, i32 1
  %2 = add i32 %0, i32 1
  %3 = add i32 %1, i32 %2
  ret i32 %3
}

define i32 @complex(i32 %0, i32 %1) {
entry:
  %2 = add i32 %0, i32 1
  %3 = add i32 %0, i32 1
  %4 = add i32 %1, i32 1
  br i32 %4, label 5, label 5

5:
  %6 = add i32 %1, i32 1
  %7 = add i32 %2, i32 %3
  %8 = add i32 %7, i32 %6
  ret i32 %8
}