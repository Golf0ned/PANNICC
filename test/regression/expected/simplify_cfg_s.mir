define i32 @simplify_cfg_delete_orphaned() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 2

1:
  store i32 2, ptr %0
  br label 3

2:
  store i32 3, ptr %0
  br label 3

3:
  %4 = load ptr %0
  ret i32 %4
}

define i32 @simplify_cfg_merge_straight_line() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  store i32 0, ptr %0
  br i32 1, label 3, label 10

3:
  br i32 2, label 4, label 5

4:
  store i32 3, ptr %2
  br label 11

5:
  %6 = load ptr %0
  %7 = add i32 %6, i32 4
  store i32 %7, ptr %1
  %8 = load ptr %1
  store i32 %8, ptr %0
  %9 = load ptr %0
  store i32 %9, ptr %2
  br label 11

10:
  store i32 5, ptr %2
  br label 11

11:
  %12 = load ptr %2
  ret i32 %12
}

define i32 @simplify_cfg_delete_empty() {
entry:
  %0 = alloca i32
  br i32 1, label 1, label 2

1:
  br i32 2, label 3, label 3

2:
  br i32 3, label 3, label 3

3:
  store i32 4, ptr %0
  %4 = load ptr %0
  ret i32 %4
}

define i32 @simplify_cfg_empty_loop() {
entry:
  %0 = alloca i32
  br label 1

1:
  br i32 0, label 1, label 2

2:
  store i32 0, ptr %0
  %3 = load ptr %0
  ret i32 %3
}