  %6 = call i32 @foo(i32 %5)
  store i32 %6, ptr %1
  store i32 2, ptr %2
  %7 = load ptr %2
  %8 = call i32 @bar(i32 %7)
  store i32 %8, ptr %3
  %9 = load ptr %1
  %10 = load ptr %3
  %11 = add i32 %9, i32 %10
  store i32 %11, ptr %1
  %12 = load ptr %1
