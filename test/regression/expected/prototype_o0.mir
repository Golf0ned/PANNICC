declare i32 @foo(i32)

declare i32 @bar(i32)

define i32 @use_proto() {
entry:
  %0 = alloca i32
  %1 = alloca i32
  %2 = alloca i32
  %3 = alloca i32
  %4 = call i32 @foo(i32 1)
  store i32 %4, ptr %0
  %5 = call i32 @bar(i32 2)
  store i32 %5, ptr %1
  %6 = load ptr %0
  %7 = load ptr %1
  %8 = add i32 %6, i32 %7
  store i32 %8, ptr %2
  %9 = load ptr %2
  store i32 %9, ptr %3
  br label 10

10:
  %11 = load ptr %3
  ret i32 %11
}