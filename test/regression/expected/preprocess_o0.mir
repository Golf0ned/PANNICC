define i32 @deref(ptr %0) {
entry:
  %1 = alloca ptr
  %2 = alloca i32
  %3 = alloca i32
  store ptr %0, ptr %1
  %4 = load ptr %1
  %5 = load ptr %4
  store i32 %5, ptr %2
  %6 = load ptr %2
  store i32 %6, ptr %3
  br label 7

7:
  %8 = load ptr %3
  ret i32 %8
}

define ptr @address(i32 %0) {
entry:
  %1 = alloca i32
  %2 = alloca ptr
  %3 = alloca ptr
  store i32 %0, ptr %1
  store ptr %1, ptr %2
  %4 = load ptr %2
  store ptr %4, ptr %3
  br label 5

5:
  %6 = load ptr %3
  ret ptr %6
}

