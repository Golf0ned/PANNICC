int deref(int * foo) {
    return *foo;
}

int * address(int foo) {
    return &foo;
}

int address_deref(int foo) {
    return *&foo;
}

int address_deref_many(int foo) {
    int *bar = &foo;
    int **baz = &bar;
    int ***qux = &baz;
    return ***qux;
}

int * return_ptr() {
    int foo = 1;
    return &foo;
}

int foo(int bar);

int bar(int foo);

int main() {
    return 0;
}